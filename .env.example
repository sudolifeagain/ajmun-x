# ============================================================================
# Required Environment Variables
# ============================================================================

# JWT Session Secret (required, minimum 32 characters)
# Used for signing session tokens. Must be different from QR_SECRET.
SESSION_SECRET=

# QR Token Secret (required, minimum 32 characters)
# Used for HMAC signing of QR tokens. Must be different from SESSION_SECRET.
QR_SECRET=

# Database URL (PostgreSQL connection string)
DATABASE_URL=

# Discord Bot Token
DISCORD_BOT_TOKEN=

# Discord OAuth2 Configuration
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

# ============================================================================
# Optional Environment Variables
# ============================================================================

# Base URL for the application (used for redirects)
NEXT_PUBLIC_BASE_URL=

# Export API Key (for Google Sheets integration, minimum 32 characters)
EXPORT_API_KEY=

# Discord Webhook URL for logging
DISCORD_LOG_WEBHOOK_URL=
